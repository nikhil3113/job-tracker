generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  jobs     Job[]
  statuses Status[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Status {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  name   String // e.g. "APPLIED", "PHONE_SCREEN"
  label  String // e.g. "Applied", "Phone Screen"
  color  String // palette color name, e.g. "blue", "amber"
  order  Int    // column display order (0, 1, 2, ...)
  userId String @db.ObjectId

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@unique([userId, name])
  @@index([userId])
}

model Job {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  company     String
  title       String
  status      String   @default("APPLIED")
  statusId    String   @db.ObjectId
  dateApplied DateTime @default(now())
  url         String?
  order       Int      @default(0)
  userId      String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusRef  Status @relation(fields: [statusId], references: [id])

  @@index([userId, statusId])
}
